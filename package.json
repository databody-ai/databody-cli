{
  "name": "@databody/cli",
  "version": "1.0.0",
  "description": "DataBody CLI - Health & Fitness Tracking for local LLMs",
  "main": "dist/index.js",
  "bin": {
    "databody": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "databody",
    "health",
    "fitness",
    "nutrition",
    "cli",
    "llm"
  ],
  "author": "DataBody",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
